{
  "env": {
    "NODE_ENV": "development",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50",
    "PORT": "3000",
    "CLAUDE_TDD_ENFORCE": "strict"
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@anthropic-ai/mcp-playwright"]
    }
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Edit(*)",
      "Write(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "WebSearch(*)",
      "TaskCreate(*)",
      "TaskUpdate(*)",
      "TaskList(*)",
      "TaskGet(*)",
      "mcp__ide__*",
      "mcp__playwright__*"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f *)",
      "Bash(npm publish*)",
      "Bash(yarn publish*)",
      "Bash(pnpm publish*)"
    ],
    "_deny_policy_note": "1차 방어 — Claude Code 레벨 차단. 프로젝트별 override 가능 (예: 라이브러리 메인테이너는 npm publish 제거). 절대 위험 (rm -rf / 등)은 hooks/command-guard.sh의 2차 방어에. 자세한 정책은 command-guard.sh 헤더 주석 참조.",
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "bash $CLAUDE_PROJECT_DIR/.claude/scripts/statusline.sh"
  },
  "autoMode": {
    "environment": [
      "개발 전용 로컬 환경. 프로덕션 접근 없음.",
      "Git 레포에서만 작업. force push 차단됨."
    ],
    "allow": [
      "src/ 내 코드 파일 읽기/수정 허용",
      "npm/node 명령 실행 허용",
      "git add, commit 허용",
      "테스트 실행 허용"
    ],
    "soft_deny": [
      "git push는 사용자 확인 필요",
      ".env, credentials 등 민감 파일 수정 차단",
      "package.json 의존성 변경 시 확인 필요",
      "데이터베이스 직접 조작 차단"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/command-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/smart-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "if": "Edit(*.ts) | Edit(*.tsx) | Edit(*.js) | Edit(*.jsx) | Write(*.ts) | Write(*.tsx) | Write(*.js) | Write(*.jsx)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tdd-enforce.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "if": "Edit(*.ts) | Edit(*.tsx) | Edit(*.js) | Edit(*.jsx) | Edit(*.css) | Edit(*.json) | Write(*.ts) | Write(*.tsx) | Write(*.js) | Write(*.jsx) | Write(*.css) | Write(*.json)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/prettier-format.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "if": "Edit(*.ts) | Edit(*.tsx) | Edit(*.js) | Edit(*.jsx) | Write(*.ts) | Write(*.tsx) | Write(*.js) | Write(*.jsx)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/eslint-fix.sh",
            "timeout": 15000
          },
          {
            "type": "command",
            "command": ".claude/hooks/test-runner.sh",
            "timeout": 60000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "if": "Edit(*.ts) | Edit(*.tsx) | Write(*.ts) | Write(*.tsx)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/typecheck.sh",
            "timeout": 30000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "if": "Edit(*.tsx) | Edit(*.jsx) | Edit(*.css) | Edit(*.scss) | Write(*.tsx) | Write(*.jsx) | Write(*.css) | Write(*.scss)",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/design-lint.sh",
            "timeout": 5000
          },
          {
            "type": "prompt",
            "prompt": "수정된 파일에서 하드코딩된 색상(hex, rgb, hsl)을 발견했다면, design-tokens.ts 토큰이나 Tailwind 클래스로 교체할 수 있는지 판단하라. 의도적 사용(SVG fill, 외부 라이브러리 등)이면 무시. 교체 가능하면 구체적 대안을 additionalContext로 반환.",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/metrics-collector.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/pattern-check.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/debate-trigger.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/readme-sync.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/tool-failure-handler.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": ".claude/hooks/model-suggest.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/budget-warn.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/context-prune.sh",
            "timeout": 8000
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-compact.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/uncommitted-warn.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": ".claude/hooks/session-review.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": ".claude/hooks/session-log.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
