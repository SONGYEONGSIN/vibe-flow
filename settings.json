{
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(find:*)",
      "Bash(git:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pnpm:*)",
      "Bash(bun:*)",
      "Bash(bunx:*)",
      "Bash(mkdir:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "defaultMode": "auto"
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/yss/.claude/statusline.sh",
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true,
    "discord@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "vibe-flow@vibe-flow": true
  },
  "extraKnownMarketplaces": {
    "vibe-flow": {
      "source": {
        "source": "git",
        "url": "https://github.com/SONGYEONGSIN/vibe-flow.git"
      }
    }
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "skipAutoPermissionPrompt": true
}
