{
  "defaults": {
    "maxRounds": 3,
    "hardLimitRounds": 5,
    "convergenceThreshold": 75,
    "maxAgents": 5,
    "debateStyle": "intense",
    "moderatorModel": "sonnet"
  },
  "templates": {
    "architecture": {
      "name": "아키텍처 리뷰",
      "agents": ["api-architect", "supabase-db-specialist", "performance-optimizer", "devops-engineer"],
      "checklist": ["확장성", "유지보수성", "성능 병목", "데이터 모델", "API 설계", "인프라/배포"]
    },
    "security": {
      "name": "보안 감사",
      "agents": ["security-specialist", "api-architect", "supabase-db-specialist"],
      "checklist": ["인증/인가", "입력 검증", "데이터 보호", "OWASP Top 10", "RLS 정책"]
    },
    "feature": {
      "name": "기능 기획",
      "agents": ["product-strategist", "frontend-design-specialist", "project-planner"],
      "checklist": ["사용자 가치", "MVP 스코프", "기술 복잡도", "UI/UX", "일정"]
    },
    "performance": {
      "name": "성능 분석",
      "agents": ["performance-optimizer", "supabase-db-specialist", "frontend-design-specialist"],
      "checklist": ["번들 크기", "렌더링 성능", "DB 쿼리", "캐싱", "Core Web Vitals"]
    },
    "discovery": {
      "name": "제품 발견",
      "agents": ["product-strategist", "ux-researcher"],
      "checklist": ["사용자 니즈", "시장 기회", "MVP 범위", "경쟁 분석", "핵심 가치 제안"]
    },
    "quality-gate": {
      "name": "품질 검증",
      "agents": ["code-reviewer", "security-specialist", "test-writer"],
      "checklist": ["코드 품질", "보안 취약점", "테스트 커버리지", "기술부채", "패턴 일관성"]
    },
    "design": {
      "name": "디자인 리뷰",
      "agents": ["ux-researcher", "frontend-design-specialist"],
      "checklist": ["사용성", "유저 플로우", "인지 부하", "접근성", "UI 일관성"]
    }
  },
  "pipelines": {
    "full-product": {
      "name": "풀 제품 개발",
      "description": "Discovery부터 배포까지 전체 제품 개발 프로세스",
      "phases": [
        { "type": "debate", "template": "discovery", "name": "Discovery" },
        { "type": "solo", "agent": "project-planner", "name": "Planning" },
        { "type": "debate", "template": "design", "name": "Design" },
        { "type": "debate", "template": "architecture", "name": "Architecture" },
        { "type": "orchestrate", "name": "Implementation" },
        { "type": "debate", "template": "quality-gate", "name": "Quality Gate" },
        { "type": "solo", "agent": "technical-writer", "name": "Documentation" },
        { "type": "solo", "agent": "deploy-safety-checker", "name": "Deploy" }
      ]
    },
    "quick-feature": {
      "name": "빠른 기능 개발",
      "description": "기획부터 품질 검증까지의 축약 프로세스",
      "phases": [
        { "type": "debate", "template": "feature", "name": "Planning" },
        { "type": "orchestrate", "name": "Implementation" },
        { "type": "debate", "template": "quality-gate", "name": "Quality Gate" }
      ]
    },
    "security-hardening": {
      "name": "보안 강화",
      "description": "보안 감사 후 수정 및 재검증",
      "phases": [
        { "type": "debate", "template": "security", "name": "Security Audit" },
        { "type": "orchestrate", "name": "Fix Implementation" },
        { "type": "debate", "template": "quality-gate", "name": "Verification" }
      ]
    }
  }
}
