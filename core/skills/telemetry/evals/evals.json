{
  "skill": "telemetry",
  "version": "1.1.0",
  "cases": [
    {
      "id": "empty-events",
      "description": "events.jsonl 없음 — 안내 메시지 + exit 0",
      "setup": {
        "files": {
          ".claude/events.jsonl": null
        }
      },
      "input": "/telemetry",
      "expected": {
        "shows_message": "events.jsonl 없음",
        "exit_code": 0
      }
    },
    {
      "id": "top-5-correct",
      "description": "5 스킬 사용 카운트 — Top 5 정확 순서",
      "setup": {
        "events_distribution_30d": {
          "commit_created": 100,
          "verify_complete": 80,
          "brainstorm": 50,
          "test": 30,
          "menu": 20,
          "status": 10
        }
      },
      "input": "/telemetry",
      "expected": {
        "top_5_order": ["/commit", "/verify", "/brainstorm", "/test", "/menu"],
        "top_1_count": 100
      }
    },
    {
      "id": "stale-detection",
      "description": "/security 30일 0회 → Stale + 개선 후보 'deprecate 검토'",
      "setup": {
        "events_distribution_30d": {
          "commit_created": 50
        }
      },
      "input": "/telemetry",
      "expected": {
        "stale_contains": "/security",
        "improvements_contains": "/security 미사용 — 사용 시나리오 발견 또는 deprecate 검토"
      }
    },
    {
      "id": "trend-increasing",
      "description": "마지막 7일 카운트 > 첫 23일 평균 → ↗ 증가",
      "setup": {
        "events_distribution_30d": {
          "commit_created": 100
        },
        "events_distribution_7d_within": {
          "commit_created": 50
        }
      },
      "input": "/telemetry trends",
      "expected": {
        "shows_increasing_arrow": "↗ 증가",
        "daily_avg_7d_higher": true
      }
    },
    {
      "id": "json-output",
      "description": "/telemetry --json — 유효 JSON + 필수 키",
      "setup": {
        "events_distribution_30d": {
          "commit_created": 50,
          "verify_complete": 30
        }
      },
      "input": "/telemetry --json",
      "expected": {
        "valid_json": true,
        "has_keys": ["analyzed_events", "period_days", "top_5", "active_7d", "stale_period", "improvements", "trends"],
        "period_days": 30
      }
    },
    {
      "id": "period-7-option",
      "description": "/telemetry --period 7 — 7일만 분석, period_days=7",
      "setup": {
        "events_distribution_30d": {
          "commit_created": 100
        },
        "events_distribution_7d_within": {
          "commit_created": 30
        }
      },
      "input": "/telemetry --json --period 7",
      "expected": {
        "valid_json": true,
        "period_days": 7,
        "analyzed_events": 30
      }
    },
    {
      "id": "period-90-option",
      "description": "/telemetry --period 90 — 90일 분석",
      "setup": {
        "events_distribution_30d": {
          "commit_created": 50
        }
      },
      "input": "/telemetry --period 90",
      "expected": {
        "shows_header": "90일 분석",
        "exit_code": 0
      }
    },
    {
      "id": "period-invalid-fallback",
      "description": "/telemetry --period 999 — 무효, 30일로 대체 + warn",
      "setup": {
        "events_distribution_30d": {
          "commit_created": 10
        }
      },
      "input": "/telemetry --period 999",
      "expected": {
        "shows_warn": "warn: --period 999 무효",
        "shows_header": "30일 분석"
      }
    }
  ]
}
