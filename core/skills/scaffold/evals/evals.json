    {
      "id": 2,
      "prompt": "/scaffold user-settings 를 실행해라. 하이픈이 포함된 도메인명을 올바르게 처리해야 한다.",
      "expectations": [
        { "description": "디렉토리 경로에 user-settings를 올바르게 사용한다", "type": "must_pass" },
